Prompt[@T, k]: {
    U: {env.user_question}
    S: {
        SUMMARY_INTRO // here is a summary of the history
        summarize_hist(@T-k)
    }
    ForEach(@t: range(1, @T-k)) {
        A: {
            AVAILABLE_TOOLS
            resp.tool_reasoning[@t]
            sys.tool_used[@t]
        }
        U: sys.tool_used[@t].tool_response
    }
    S: INSTRUCTION // choose an action or declare done
}