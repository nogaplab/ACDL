Prompt[@t]: {
    U: {env.user_question}
    S: {
        SUMMARY_INTRO // here is a summary of the history
        summarize_hist(@t-k)
    }
    ForEach(i: range(1, @t-k)) {
        A: {
            AVAILABLE_TOOLS
            resp.tool_reasoning[@i]
            sys.tool_used[@i]
        }
        U: {sys.tool_used[@i].tool_response[@i]}
    }
    S: {INSTRUCTION // choose an action or declare done}
}