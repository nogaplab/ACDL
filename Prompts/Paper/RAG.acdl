RAG[@T]: {
    MARK 1{
        S: INSTRUCTIONS
    }
    U: {
        env.user_input
        MARK 2 {
            If sys.use_rag {
                MARK 3 {
                    ForEach(i: range(1,retrieve(env.user_input).len)) {
                        retrieve(env.user_input)[i]
                    }
                }
                ANSWER_QUESTION_BASED_ON_DOCS
            }
            Else {
                ANSWER_QUESTION
            }
        }
    }
}