Planner[@T, context, task]: {
    S: {
        TASK_DESC  // you are an assitant who's job is to make a plan to solve the user's question
        AVAILABLE_TOOLS
    }
    U: context  // the history of the other agent's actions and tasks, to be used to make the plan
    U: task  // the user's question to be answered for the other agent, to be used to make the plan
    ForEach(t: range(1,T)) {
        A: {
            resp.tool_reasoning[@t]
            sys.tool_used[@t]
        }
        T: sys.tool_used[@t].tool_response
    }

    S: INSTRUCTION   // choose an action, or create the plan if you feel you have everything you need to do so
}
