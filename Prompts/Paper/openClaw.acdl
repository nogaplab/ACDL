OpenClaw[@T.I]: {
// TODO: 
// - system
// - [[reply to current]]
// - system messages in user roles
S: {
	SystemPrompt // TODO the long system prompt
}
// summarized early conversation (if exists)
If (sys.last_compaction_turn[@T] > 0) {
	U: { 
		THIS_IS_A_SUMMARY
		ConversationSummary()[@sys.last_compaction_turn] // XXX how do we represent this?
	}
	A: resp.response[@sys.last_compaction_turn] // XXX  should it be resp.response?
// conversation history
ForEach(t: range(@sys.last_compaction_turn + 1, @T)) {
	U: {
		// This list is often empty
		MARK 1{
            ForEach(m: range(1,sys.pending_messages[@t].len)) {
                sys.pending_messages[@t][m].date_time
                sys.pending_messages[@t][m].message
            }
        }
		sys.date_time[@t]
		env.user_query[@t] 
	}
	If (@t == @T) { // XXX END
	}
	// XXX i like @t.substeps better than alternative
	// tool-using loop history
	ForEach(i: range(1,@t.substeps)) { 
		// multiple requests in one assistant message
		A: {
			ForEach(tool: sys.tool_requests[@t.i]) {
	            sys.tool.id_name_and_args // XXX its actually an array of these tool calls, called "tool_calls"
	         }
	    }
	    // Loop of tool responses, each in own tool msg
	    ForEach(tool: sys.tool_requests[@t.i]) {
	        T: { 
	            sys.tool.id_and_response // XXX i don't want sys., but it requires it
	        }
		}
	}
        If (@t < @T) {
	A: resp.response[@t] // XXX should it be resp.response? 
        }
	
}
}
}
