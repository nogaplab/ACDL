ReactWithPlanner[@T.I]: {
    S: {
        TASK_DESC  // you are an assistant who's job is...
        AVAILABLE_TOOLS
    }
    MARK 1 {
        History{
            ForEach(@t: range(1,@T-1)) {
                U: env.user_question[@t]
                ForEach(i: range(1,sys.substeps[@t])) {
                    A: {
                        resp.tool_reasoning[@t.i]
                        sys.tool_used[@t.i]
                    }
                    T: sys.tool_used[@t.i].tool_response
                }
                A: resp.response[@t]
            }
            
            U: env.user_question[@T]
                ForEach(i: range(1,I)) {
                A: {
                    resp.tool_reasoning[@T.i]
                    sys.tool_used[@T.i]
                }
                T: sys.tool_used[@T.i].tool_response
            }
        }
    }

    Switch (sys.tool_used[@T.I].tool_name) {
        Case "Planner": {
            S: INSTRUCTION   // choose an action, use the plan made by planner
            A: planner(prompt.History[@T.I], env.user_question[@T])  // call the planner with the history and the current user question to get the plan
        }
        Default {
            S: INSTRUCTION   // choose an action, use ReACT
        }
    }

    S: INSTRUCTION   // choose an action, use ReACT
}