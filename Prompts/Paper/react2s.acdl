React2Short[@T.I]: {
    S: INSTRUCTIONS_AND_TOOLS
    // History
    // Chat loop (Main loop)
    ForEach(t: range(1,@T)) {
        U: env.user_question[@t]
    PromptEndsHere when (@t==@T and @T.0)
        // React loop (internal loop)
        ForEach(i: range(1,@t.substeps)) {
          A: sys.tool_used[@t.i].name_and_args
          T: sys.tool_used[@t.i].tool_response
        }
        PromptEndsHere when (@t==@T and @T.I)
        A: resp.response // response after ReAct loop
    }
}