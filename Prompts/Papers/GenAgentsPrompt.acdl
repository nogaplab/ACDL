Prompt[@t, agent_name]: {
	S: sys.agent_desc[agent_name] // a description of the agent's personality, goals, and background
	U: env.datetime[@t]  // the current date and time in the Sims like environment
	U: sys.status[@t] // what the agent is currently doing
	U: env.current_observation[@t] // what the agent is currently observing in the environment
	A: get_context_summary(@t, sys.agent_names[agent_name], sys.conversation_topic) // retrieve a summary of the relevant context information
	ForEach(other_agent_name: sys.agent_names){
		If env.in_dialog(Other_agent_name) {
			U: get_dialog_history(sys.agent_names[other_agent_name]) // the recent dialog history with the other agent
		}
	}
	S: QUESTION // e.g., "How would Eddy respond to John?"
}
