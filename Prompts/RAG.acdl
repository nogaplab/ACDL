Prompt[@T]: {
    S: ROLE_DESCRIPTION // you are an assistant who’s job is…
    ForEach(@t: range(1,@T-1)) {
	    U: env.user_input[@t]
        U: {
            ForEach(k: range(1,sys.RAG_resp[@t].len)){
                sys.RAG_resp[@t][k]
            }
        }
        A: resp.LLM_text[@t]
	}
    Switch env.user_input[@t] {
	    Case "bad answer" {
            name improved_response := improve_RAG_response(env.user_input[@t], sys.RAG_resp[@t]) 
		    U: {ForEach(i: range(1,improved_response.len)){
                improved_response[i]}
            }
            S: {INSTRUCTIONS // not good enough, get better results}
		}
	    Default { 
            U: {ForEach(i: range(1,sys.RAG_resp.len)) { 
			        sys.RAG_resp[@t][i]}
            }
        }
    }
}
