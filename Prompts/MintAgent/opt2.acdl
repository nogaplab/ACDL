Mint2[@t]: {
    U: {
        TASK_DESCRIPTION(sys.max_total_steps)
        env.tool_desc
        env.in_context_example
        env.task_prompt
    } 
    
    // all the tool calls and reponses from all turns
    ForEach(@i: range(1,@t)) {
        A: { 
            ForEach(k: range(1, sys.steps[@i])){
                sys.tool_used[@i.k]
                sys.tool_used[@i.k].tool_response
            }
        }
        If @i<@t {
            A: {
                resp.solution_reasoning[@i]
                resp.solution[@i]
            }
            U: env.feedback[@i] // response if the answer was right or wrong, remaining tries if failed
        }
    
    }  
}