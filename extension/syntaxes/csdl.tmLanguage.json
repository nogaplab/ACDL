{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CSDL",
  "scopeName": "source.csdl",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#prompt-declaration" },
    { "include": "#role-identifier" },
    { "include": "#namespace-keyword" },
    { "include": "#control-keyword" },
    { "include": "#template" },
    { "include": "#range-operator" },
    { "include": "#operator" },
    { "include": "#context-variable-path" },
    { "include": "#index-expression" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "match": "//[^}]*",
      "name": "comment.line.double-slash.csdl"
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.csdl",
      "patterns": [
        {
          "match": "\\\\[\"\\\\nt]",
          "name": "constant.character.escape.csdl"
        }
      ]
    },
    "number": {
      "match": "\\b[0-9]+\\b",
      "name": "constant.numeric.csdl"
    },
    "prompt-declaration": {
      "match": "\\b(Prompt)\\b",
      "name": "keyword.other.prompt.csdl"
    },
    "role-identifier": {
      "match": "\\b([SUATN])(?=\\s*:)",
      "captures": {
        "1": { "name": "entity.name.tag.role.csdl" }
      }
    },
    "namespace-keyword": {
      "match": "\\b(env|sys|resp|prompt)\\b",
      "name": "keyword.other.namespace.csdl"
    },
    "control-keyword": {
      "match": "\\b(If|ElseIf|Else|ForEach|Switch|Case|Default|break|continue)\\b",
      "name": "keyword.control.csdl"
    },
    "template": {
      "match": "\\b([A-Z][A-Z0-9_]+)\\b",
      "name": "entity.name.function.template.csdl"
    },
    "range-operator": {
      "match": "\\.\\.\\.|\\u2026",
      "name": "keyword.operator.range.csdl"
    },
    "operator": {
      "match": "[=!<>&|^+\\-*/%]",
      "name": "keyword.operator.csdl"
    },
    "context-variable-path": {
      "match": "(?<=\\b(?:env|sys|resp|prompt))\\.([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "variable.other.property.csdl" }
      }
    },
    "index-expression": {
      "match": "@([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "0": { "name": "variable.parameter.index.csdl" }
      }
    },
    "punctuation": {
      "match": "[{}()\\[\\]:;,@#$?_]",
      "name": "punctuation.csdl"
    }
  }
}
