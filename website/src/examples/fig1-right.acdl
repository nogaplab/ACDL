ReactToolRagAtEnd[@T]: {
  S: {
    INSTRUCTIONS
  }
  U: env.user_input[@1]
  // history
  ForEach(t: range(1,@T-1)) {
    A: {
      resp.tool_reasoning[@t] 
      sys.tool_used[@t]
    }
    T: sys.tool_used[@t].tool_response
  }
  S: {
    Mark 1 {
    locate_tools(env.user_input[@1])
    }
    USE_TOOLS_TO_SOLVE_TASK 
  }
}