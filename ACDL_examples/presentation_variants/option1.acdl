Option1[@T.I]: {
    S: {
        TASK_DESCRIPTION
        env.tool_descriptions // description of each tool, how to use them, and when to use them
        env.in_context_examples
    }
    // previous turns
    ForEach(@t: range(1,@T)) {
        ForEach(i: range(1, @t.substeps)) {
            A: sys.tool_used[@t.i]
            T: sys.tool_used[@t.i].tool_response
        }
    }
    // current turn
    ForEach(i: range(1, I)) {
        A: sys.tool_used[@T.i]
        T: sys.tool_used[@T.i].tool_response
    }
}