Option2[@T.I]: {
    S: {
        TASK_DESCRIPTION
        env.tool_descriptions // description of each tool, how to use them, and when to use them
        env.in_context_examples
    }

    A: {
        // previous turns
        ForEach(@t: range(1,@T)) {
            ForEach(i: range(1, @t.substeps)) {
                resp.tool_reasoning[@t.i] 
                sys.tool_used[@t.i]
                sys.tool_used[@t.i].tool_response
            }
        }
        // current turn
        ForEach(i: range(1, I)) {
            resp.tool_reasoning[@T.i]
            sys.tool_used[@T.i]
            sys.tool_used[@T.i].tool_response
        }
    }

}