Option2[@T]: {
    U: {
        TASK_DESCRIPTION(sys.max_total_steps)
        env.tool_desc
        env.in_context_example
        env.task_prompt
    } 
    
    // all the tool calls and reponses from all turns
    ForEach(@t: range(1,@T)) {
        A: { 
            ForEach(i: range(1, @t.substeps)){
                sys.tool_used[@t.i]
                sys.tool_used[@t.i].tool_response
            }
        }
        A: {
            resp.solution_reasoning[@t]
            resp.solution[@t]
        }
        U: env.feedback[@t] // response if the answer was right or wrong, remaining tries if failed
    } 
    
    ForEach(i: range(1, @T.substeps)) {
        A: {
            sys.tool_used[@T.i]
            sys.tool_used[@T.i].tool_response
        }
    }
}