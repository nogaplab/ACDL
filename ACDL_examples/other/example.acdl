AgentPrompt[@T]: {
    A: {
        resp.CreateRoutine[@T].def
        resp.MakePlan[@T].abc
    }
}


CreateRoutine[@T]: {
    S: INSTRUCTIONS
}


MakePlan[@T]: {
    S: INSTRUCTIONS
    A: resp.CreateRoutine[@T]
}


