Prompt[@T.I]: {
    U: {
        TASK_DESCRIPTION(sys.max_total_steps)
        env.tool_desc
        env.in_context_example
        env.task_prompt
    } 

    // only the result of the previous turns or the new query in them
    ForEach(@t: range(1, @T-1)){
        A: {
            resp.solution_reasoning[@t]
            resp.solution[@t]
        }
        U: env.user_input[@t]  // could be a new query/task, or a response to a solution(success or failure)
    }

    // all the tool calls and reponses from the current turn
    ForEach(i: range(1, I-1)){
        A: { 
            sys.tool_used[@T.i]
            sys.tool_used[@T.i].tool_response
        }
    }
}