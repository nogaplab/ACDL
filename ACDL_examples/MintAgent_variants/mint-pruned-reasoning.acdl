Var4[@T.I]: {
    U: {
        TASK_DESCRIPTION(sys.max_total_steps)
        env.tool_descriptions // description of each tool, how to use them, and when to use them
        env.in_context_examples
        env.task_prompt // the question you need to answer, or task you need to complete
    }

    ForEach(@t: range(1,@T)) {
        ForEach(i: range(1, @t.substeps)) {
            A: sys.tool_used[@t.i]
            U: sys.tool_used[@t.i].tool_response
        }
    A: {
        resp.solution_reasoning[@t]
        resp.solution[@t]
    }
    U: env.feedback[@t.i] // response if the answer was right or wrong, remaining tries if failed
    }
    

    ForEach(i: range(1, @T.substeps)) {
        A: sys.tool_used[@T.i]
        U: sys.tool_used[@T.i].tool_response
    }

}